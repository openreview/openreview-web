{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "printWidth": 95,
  "trailingComma": "es5",
  "sortImports": {
    "newlinesBetween": false,
    "groups": [
      "builtin",
      "external",
      ["internal", "subpath"],
      ["parent", "sibling", "index"],
      "side_effect",
      "unknown",
      { "newlinesBetween": true },
      ["style", "side_effect_style"]
    ]
  },
  "sortPackageJson": false,
  "ignorePatterns": [
    "/node_modules",
    "/videos",
    "/.next",
    "/client/templates.js",
    "/client/templates",
    "/public/error-styles.css"
  ]
}
